<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Henry & Nesley — Bali Wedding Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #ffffff;
    --sidebar-bg: #f7f6f3;
    --text: #37352f;
    --text-light: #6b6b6b;
    --accent: #2eaadc;
    --red: #e03e3e;
    --orange: #d9730d;
    --green: #0f7b6c;
    --yellow: #dfab01;
    --purple: #6940a5;
    --pink: #ad1a72;
    --blue: #0b6e99;
    --tag-red-bg: #fbe4e4;
    --tag-orange-bg: #faebdd;
    --tag-green-bg: #dbeddb;
    --tag-yellow-bg: #fdecc8;
    --tag-purple-bg: #e8deee;
    --tag-blue-bg: #ddebf1;
    --tag-pink-bg: #f4dfeb;
    --tag-gray-bg: #e3e2e0;
    --border: #e9e9e7;
    --hover: #f1f1ef;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Inter',sans-serif; color:var(--text); background:var(--bg); line-height:1.6; }
  
  .page { max-width:960px; margin:0 auto; padding:20px 24px 60px; }
  
  .page-header { margin-bottom:32px; padding-bottom: 16px; border-bottom: 1px solid var(--border);}
  .page-icon { font-size:48px; margin-bottom:8px; }
  .page-title { font-size:32px; font-weight:700; margin-bottom:4px; }
  .page-subtitle { color:var(--text-light); font-size:14px; }
  
  .overview-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap:12px; margin-bottom:32px; }
  .overview-card { background:var(--sidebar-bg); border-radius:8px; padding:16px; }
  .overview-card .label { font-size:12px; color:var(--text-light); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:4px;}
  .overview-card .value { font-size:18px; font-weight:600; }
  
  .section { margin-bottom:36px; }
  .section-header { display:flex; align-items:center; gap:8px; margin-bottom:12px; cursor:pointer; user-select:none;}
  .section-header h2 { font-size:20px; font-weight:600; }
  .section-header .toggle { font-size:12px; color:var(--text-light); transition:transform 0.2s;}
  .section-header .toggle.collapsed { transform:rotate(-90deg); }
  
  .tag { display:inline-block; padding:2px 8px; border-radius:4px; font-size:12px; font-weight:500; white-space:nowrap; }
  .tag-red { background:var(--tag-red-bg); color:var(--red); }
  .tag-orange { background:var(--tag-orange-bg); color:var(--orange); }
  .tag-green { background:var(--tag-green-bg); color:var(--green); }
  .tag-yellow { background:var(--tag-yellow-bg); color:var(--yellow); }
  .tag-purple { background:var(--tag-purple-bg); color:var(--purple); }
  .tag-blue { background:var(--tag-blue-bg); color:var(--blue); }
  .tag-pink { background:var(--tag-pink-bg); color:var(--pink); }
  .tag-gray { background:var(--tag-gray-bg); color:var(--text-light); }
  
  table { width:100%; border-collapse:collapse; font-size:14px; }
  th { text-align:left; padding:8px 12px; border-bottom:2px solid var(--border); font-weight:600; font-size:12px; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-light); background:var(--sidebar-bg);}
  td { padding:8px 12px; border-bottom:1px solid var(--border); vertical-align:top; }
  tr:hover td { background:var(--hover); }
  
  .task-list { list-style:none; }
  .task-list li { display:flex; align-items:flex-start; gap:10px; padding:8px 4px; border-bottom:1px solid var(--border); font-size:14px;}
  .task-list li:last-child { border-bottom:none; }
  .checkbox { width:18px; height:18px; border:2px solid #c4c4c4; border-radius:4px; flex-shrink:0; margin-top:2px; cursor:pointer; display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--green);transition:all 0.15s;}
  .checkbox.checked { background:var(--green); border-color:var(--green); color:#fff;}
  .task-text.done { text-decoration: line-through; color: var(--text-light); }
  .task-meta { display:flex; gap:6px; margin-top:4px; flex-wrap:wrap; }
  
  .timeline { position:relative; padding-left:24px; }
  .timeline::before { content:''; position:absolute; left:8px; top:8px; bottom:8px; width:2px; background:var(--border); }
  .timeline-item { position:relative; margin-bottom:16px; }
  .timeline-item::before { content:''; position:absolute; left:-20px; top:6px; width:12px; height:12px; border-radius:50%; border:2px solid var(--accent); background:#fff; }
  .timeline-item.done::before { background:var(--green); border-color:var(--green); }
  .timeline-item.current::before { background:var(--orange); border-color:var(--orange); animation:pulse 2s infinite; }
  @keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(217,115,13,0.4)} 50%{box-shadow:0 0 0 6px rgba(217,115,13,0)} }
  .timeline-date { font-size:12px; color:var(--text-light); font-weight:500; }
  .timeline-content { font-size:14px; }
  
  .callout { background:#fef3dd; border-radius:8px; padding:16px; margin-bottom:16px; display:flex; gap:12px; align-items:flex-start; }
  .callout-icon { font-size:20px; flex-shrink:0; }
  .callout-text { font-size:14px; }
  .callout-red { background:#fbe4e4; }
  
  .tabs { display:flex; gap:0; border-bottom:1px solid var(--border); margin-bottom:16px; overflow-x:auto; }
  .tab { padding:8px 16px; font-size:14px; font-weight:500; cursor:pointer; border-bottom:2px solid transparent; color:var(--text-light); white-space:nowrap; transition:all 0.15s;}
  .tab.active { color:var(--text); border-bottom-color:var(--text); }
  .tab:hover { background:var(--hover); }
  .tab-content { display:none; }
  .tab-content.active { display:block; }
  
  @media(max-width:600px){
    .page { padding:12px 12px 40px; }
    .page-title { font-size:24px; }
    .overview-grid { grid-template-columns:1fr 1fr; }
    table { font-size:12px; }
    th,td { padding:6px 8px; }
    .tab { padding:6px 10px; font-size:13px;}
  }
  
  .progress-bar { height:8px; background:var(--border); border-radius:4px; overflow:hidden; margin-top:4px; }
  .progress-fill { height:100%; border-radius:4px; transition:width 0.5s; }
  
  .vendor-card { border:1px solid var(--border); border-radius:8px; padding:14px; margin-bottom:10px; }
  .vendor-card .vendor-name { font-weight:600; font-size:15px; }
  .vendor-card .vendor-detail { font-size:13px; color:var(--text-light); margin-top:4px; }
  
  .scroll-table { overflow-x:auto; }
</style>
</head>
<body>
<div class="page">

  <!-- HEADER -->
  <div class="page-header">
    <div class="page-icon">💒</div>
    <div class="page-title">Henry & Nesley — Bali Wedding</div>
    <div class="page-subtitle">📅 October 3, 2026 &nbsp;·&nbsp; 📍 Jeeva Saba Villa, Sanur, Bali &nbsp;·&nbsp; 👥 ~25 guests &nbsp;·&nbsp; 🎨 Satin & Sand palette</div>
  </div>

  <!-- OVERVIEW CARDS -->
  <div class="overview-grid">
    <div class="overview-card">
      <div class="label">Days to Wedding</div>
      <div class="value" id="countdown"></div>
    </div>
    <div class="overview-card">
      <div class="label">Next Trip to Bali</div>
      <div class="value" style="font-size:15px;">May 13–16, 2026</div>
    </div>
    <div class="overview-card">
      <div class="label">Vendors Confirmed</div>
      <div class="value">7 / 10</div>
    </div>
    <div class="overview-card">
      <div class="label">Pending Actions</div>
      <div class="value" style="color:var(--red);">12 items</div>
    </div>
  </div>

  <!-- URGENT CALLOUT -->
  <div class="callout callout-red">
    <div class="callout-icon">🚨</div>
    <div class="callout-text">
      <strong>Respond Today:</strong> Dhony asked you to pick <strong>3–4 canapé items</strong> for the May 15 tasting. Also share your <strong>Bali hotel details</strong> ASAP so he can finalize the trip itinerary.
    </div>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <div class="tab active" onclick="switchTab(event,'tasks')">📋 Pending Tasks</div>
    <div class="tab" onclick="switchTab(event,'vendors')">🤝 Vendors</div>
    <div class="tab" onclick="switchTab(event,'payments')">💰 Payments</div>
    <div class="tab" onclick="switchTab(event,'timeline')">📅 Timeline</div>
    <div class="tab" onclick="switchTab(event,'accommodation')">🏠 Accommodation</div>
    <div class="tab" onclick="switchTab(event,'menu')">🍽️ Menu & Catering</div>
    <div class="tab" onclick="switchTab(event,'ceremony')">💍 Ceremony & Entertainment</div>
    <div class="tab" onclick="switchTab(event,'trip')">✈️ May Trip</div>
    <div class="tab" onclick="switchTab(event,'decisions')">📝 Key Decisions Log</div>
  </div>

  <!-- TAB: PENDING TASKS -->
  <div class="tab-content active" id="tasks">
    <div class="section">
      <div class="callout" style="background:#fff8e1;">
        <div class="callout-icon">💡</div>
        <div class="callout-text">Click checkboxes to track your progress. Tasks are sorted by urgency.</div>
      </div>

      <h3 style="margin:12px 0 8px;color:var(--red);">🔴 Urgent — Respond to Dhony/Liz</h3>
      <ul class="task-list">
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Select 3–4 canapé items from the menu Dhony sent (Apr 17)</span><div class="task-meta"><span class="tag tag-red">Overdue</span><span class="tag tag-orange">Catering</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Share hotel booking details for May 13–15 Bali trip</span><div class="task-meta"><span class="tag tag-red">Blocking</span><span class="tag tag-blue">Trip</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Confirm if decor mock-up during visit works (Dhony checking with Belle Eloise)</span><div class="task-meta"><span class="tag tag-orange">Waiting</span><span class="tag tag-purple">Decor</span></div></div></li>
      </ul>

      <h3 style="margin:16px 0 8px;color:var(--orange);">🟠 High Priority — This Month</h3>
      <ul class="task-list">
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Upload pre-wedding photos to WithJoy website</span><div class="task-meta"><span class="tag tag-orange">Blocks invitations</span><span class="tag tag-blue">Website</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Review & pay Moira music invoice (received Apr 9)</span><div class="task-meta"><span class="tag tag-orange">Payment due</span><span class="tag tag-pink">Music</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Review & pay RTM fire dance invoice (received Apr 7)</span><div class="task-meta"><span class="tag tag-orange">Payment due</span><span class="tag tag-pink">Entertainment</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Select fireworks package from pricelist (sent Mar 8)</span><div class="task-meta"><span class="tag tag-orange">Pending decision</span><span class="tag tag-pink">Entertainment</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Provide twin bed name list to Dhony (promised Jan 13)</span><div class="task-meta"><span class="tag tag-red">Overdue</span><span class="tag tag-blue">Accommodation</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Finalize rooming list for both Jeeva Saba & Saba Biara 5BR</span><div class="task-meta"><span class="tag tag-orange">Pending</span><span class="tag tag-blue">Accommodation</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Review comprehensive budget breakdown (Google Sheet shared Mar 13)</span><div class="task-meta"><span class="tag tag-orange">Pending</span><span class="tag tag-yellow">Budget</span></div></div></li>
      </ul>

      <h3 style="margin:16px 0 8px;color:var(--yellow);">🟡 Medium Priority — Before May Trip</h3>
      <ul class="task-list">
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Confirm officiant — will your MC double as celebrant? Confirm who the MC is.</span><div class="task-meta"><span class="tag tag-yellow">Decision needed</span><span class="tag tag-purple">Ceremony</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Decide on dress code for guests (needed for website update)</span><div class="task-meta"><span class="tag tag-yellow">Decision needed</span><span class="tag tag-blue">Website</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Decide if you're having a first dance (needed for rundown & website)</span><div class="task-meta"><span class="tag tag-yellow">Decision needed</span><span class="tag tag-purple">Ceremony</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Confirm Belle Eloise decor details: mirror style, dance floor color, keepsake color, phone booth, table arrangement</span><div class="task-meta"><span class="tag tag-yellow">In progress</span><span class="tag tag-purple">Decor</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Coordinate Phone a Friend photo booth setup with decorator (video add-on)</span><div class="task-meta"><span class="tag tag-yellow">Pending</span><span class="tag tag-purple">Decor</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Collect guest personal information (passport details for rooming list, visa checks)</span><div class="task-meta"><span class="tag tag-yellow">Pending</span><span class="tag tag-blue">Guests</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Check all guests have arrival cards & visas (China-born guests need visa)</span><div class="task-meta"><span class="tag tag-yellow">Pending</span><span class="tag tag-blue">Guests</span></div></div></li>
      </ul>

      <h3 style="margin:16px 0 8px;color:var(--green);">🟢 Lower Priority — Before Wedding</h3>
      <ul class="task-list">
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Publish WithJoy website (after PW photos uploaded)</span><div class="task-meta"><span class="tag tag-green">After photos</span><span class="tag tag-blue">Website</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Send digital invitations to all guests via WithJoy</span><div class="task-meta"><span class="tag tag-green">After publish</span><span class="tag tag-blue">Invitations</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Design & order hard copy invitations (Taobao — Liz's suggestion)</span><div class="task-meta"><span class="tag tag-green">Anytime</span><span class="tag tag-blue">Invitations</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Rent wedding gown in HK & arrange transport to Bali</span><div class="task-meta"><span class="tag tag-green">Before Oct</span><span class="tag tag-pink">Attire</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Prepare Spotify playlists (guest arrival, after party)</span><div class="task-meta"><span class="tag tag-green">Before Oct</span><span class="tag tag-pink">Music</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Purchase disposable cameras for guests (Etsy or local)</span><div class="task-meta"><span class="tag tag-green">Before Oct</span><span class="tag tag-gray">Misc</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Finalize website additions: checklist for guests, brief itinerary, "Things to do in Bali" with local recommendations</span><div class="task-meta"><span class="tag tag-green">Before publish</span><span class="tag tag-blue">Website</span></div></div></li>
        <li><div class="checkbox" onclick="toggleCheck(this)"></div><div><span class="task-text">Arrange welcome dinner at villa for bridal party & in-house guests (Oct 2 evening)</span><div class="task-meta"><span class="tag tag-green">Before Oct</span><span class="tag tag-orange">Catering</span></div></div></li>
      </ul>
    </div>
  </div>

  <!-- TAB: VENDORS -->
  <div class="tab-content" id="vendors">
    <div class="section">
      <h3 style="margin-bottom:12px;">✅ Confirmed Vendors</h3>
      <div class="vendor-card">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">🎪 Avavi Bali — Wedding Planner</span><span class="tag tag-green">Confirmed</span></div>
        <div class="vendor-detail">Dhony (planner) + Elisabeth/Liz (owner) + Ivonnela (finance). Group created Jul 3, 2025.</div>
      </div>
      <div class="vendor-card">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">🏖️ Jeeva Saba — Wedding Venue + Bride Accommodation</span><span class="tag tag-green">Confirmed</span></div>
        <div class="vendor-detail">8 rooms. Beach House Room 222 reserved for Henry & Nesley (best sunset view). Extra beds IDR 500,000++/person/night, max 6 total.</div>
      </div>
      <div class="vendor-card">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">🏡 Kutus Kutus Saba Biara — 5BR Beachfront Villa</span><span class="tag tag-green">Booked</span></div>
        <div class="vendor-detail">Changed from 4BR Saba Garden. Private, beachfront. ~17 min walk / 5 min drive from Jeeva. Invoice received Jan 20. For groomsmen + plus ones + new male guest.</div>
      </div>
      <div class="vendor-card">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">🍽️ Lumbung Catering — Food & Beverage</span><span class="tag tag-green">Deposit Paid</span></div>
        <div class="vendor-detail">3-course set menu + canapé cocktail + food stall for after party. Tasting May 15 at 1pm. Deposit IDR 10M paid.</div>
      </div>
      <div class="vendor-card">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">📸 Pyara — Photo + Video Bundle</span><span class="tag tag-green">Deposit Paid</span></div>
        <div class="vendor-detail">Bundle: Gejoo (photo) × Bulgary (video). 12 hours (11am–11pm). 50% deposit paid Jan 1, 2026.</div>
      </div>
      <div class="vendor-card">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">💐 Belle Eloise — Decorator</span><span class="tag tag-yellow">Confirmed, details WIP</span></div>
        <div class="vendor-detail">Chosen over Flower Lace (more economical). Revised quote received Jan 13. Moodboard and specific items still being finalized.</div>
      </div>
      <div class="vendor-card">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">🎵 Moira Ensembles — Live Music</span><span class="tag tag-orange">Invoice received, unpaid</span></div>
        <div class="vendor-detail">Ceremony: Harp & Cello duo. Cocktail + Dinner: Trio (guitar, keyboard, vocalist). Invoice sent Apr 9.</div>
      </div>
      <div class="vendor-card">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">🔥 RTM (Relations Talent Management) — Fire Dance</span><span class="tag tag-orange">Invoice received, unpaid</span></div>
        <div class="vendor-detail">4 dancers, performing before dinner transition. Invoice sent Apr 7.</div>
      </div>

      <h3 style="margin:20px 0 12px;">⏳ Pending / Not Yet Booked</h3>
      <div class="vendor-card" style="border-color:var(--orange);">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">🎆 Fireworks Vendor</span><span class="tag tag-red">Not selected</span></div>
        <div class="vendor-detail">Pricelist shared Mar 8. You said yes to fireworks but haven't picked a package.</div>
      </div>
      <div class="vendor-card" style="border-color:var(--orange);">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">💒 Officiant / Celebrant</span><span class="tag tag-red">Not confirmed</span></div>
        <div class="vendor-detail">No Cantonese-speaking celebrant in Bali (would need to hire from Malaysia). Discussed having MC double as celebrant — not confirmed. Celebrant recommendations in Google Drive folder.</div>
      </div>
      <div class="vendor-card" style="border-color:var(--orange);">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">📱 Phone a Friend — Photo Booth</span><span class="tag tag-yellow">Discussed, not booked</span></div>
        <div class="vendor-detail">Henry wants video setup add-on. Need to coordinate with decorator for entrance placement. IG: @phoneafriend.co</div>
      </div>
      <div class="vendor-card" style="border-color:var(--text-light);border-style:dashed;">
        <div style="display:flex;justify-content:space-between;flex-wrap:wrap;"><span class="vendor-name">💄 MUA — Makeup Artist</span><span class="tag tag-gray">Not needed</span></div>
        <div class="vendor-detail">Nesley confirmed no MUA needed (Nov 19). However, later mentioned MUA & assistant staying at Jeeva Saba — clarify if this changed.</div>
      </div>
    </div>
  </div>

  <!-- TAB: PAYMENTS -->
  <div class="tab-content" id="payments">
    <div class="section">
      <div class="callout">
        <div class="callout-icon">💰</div>
        <div class="callout-text">Payment record maintained by Dhony: <a href="https://docs.google.com/spreadsheets/d/1_VTKkkhQOfcjOr2EBz7a9m929K-XnCts/edit?gid=567412398#gid=567412398" target="_blank" style="color:var(--accent);">Google Sheet</a><br>Budget breakdown: <a href="https://docs.google.com/spreadsheets/d/1qkaJeMJRcu9jbNaMrm8ebJx3SFJ3z7af/edit?gid=1923715271#gid=1923715271" target="_blank" style="color:var(--accent);">Google Sheet</a></div>
      </div>
      <div class="scroll-table">
      <table>
        <thead><tr><th>Date</th><th>Item</th><th>Amount (IDR)</th><th>Paid To</th><th>Status</th></tr></thead>
        <tbody>
          <tr><td>Dec 2, 2025</td><td>Kutus Kutus 4BR — 2 nights deposit (50%)</td><td>10,398,000</td><td>Avavi Bali</td><td><span class="tag tag-green">Paid</span></td></tr>
          <tr><td>Dec 2, 2025</td><td>Lumbung Catering — date blocking deposit</td><td>10,000,000</td><td>Avavi Bali</td><td><span class="tag tag-green">Paid</span></td></tr>
